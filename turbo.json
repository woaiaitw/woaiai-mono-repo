{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "dependsOn": ["db:migrate:local"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "deploy": {
      "dependsOn": ["build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate:local": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "test:e2e": {
      "cache": false
    }
  }
}
