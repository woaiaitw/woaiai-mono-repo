{
  "name": "video-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply VIDEO_DB --local",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@web-template/shared": "workspace:*",
    "agora-token": "^2.0.3",
    "drizzle-orm": "^0.41",
    "hono": "^4",
    "nanoid": "^5"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.13",
    "@cloudflare/workers-types": "^4",
    "@vitest/runner": "~3.2.4",
    "@vitest/snapshot": "~3.2.4",
    "drizzle-kit": "^0.31",
    "typescript": "^5.7",
    "vitest": "^3.2.4",
    "wrangler": "^4"
  }
}
